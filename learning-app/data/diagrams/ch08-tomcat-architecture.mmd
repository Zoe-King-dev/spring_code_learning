graph TB
    subgraph Tomcat["Tomcat 实例"]
        Service[Service]
    end

    subgraph Connector层["Connector（连接器）"]
        Coyote[Coyote Adapter]
        NIO[NIO Endpoint<br/>server.port 监听]
    end

    subgraph Engine层["Engine（Servlet 引擎）"]
        Host[Host<br/>localhost]
    end

    subgraph Context层["TomcatEmbeddedContext"]
        SC[ServletContext]
        DS[DispatcherServlet]
        Filters[Filter 链]
    end

    Service --> Coyote
    Coyote --> NIO
    NIO -->|HTTP 请求| Host
    Host --> SC
    SC --> Filters
    Filters --> DS
    DS -->|处理请求| Controllers[(Spring Controller Bean)]

    classDef tomcatStyle fill:#fff3e0,stroke:#ef6c00,stroke-width:2px
    classDef connectorStyle fill:#e3f2fd,stroke:#1565c0
    classDef contextStyle fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    class Service,Coyote tomcatStyle
    class NIO,Host connectorStyle
    class SC,DS,Filters,Controllers contextStyle
